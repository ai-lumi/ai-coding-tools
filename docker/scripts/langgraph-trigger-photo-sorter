#!/bin/bash
# langgraph-trigger-photo-sorter — 触发照片分拣工作流
#
# 用法：
#   langgraph-trigger-photo-sorter [源目录] [目标目录]
#
# 默认：
#   源目录 = /data/photos
#   目标目录 = /data/photos/sorted
#
# 示例：
#   langgraph-trigger-photo-sorter /data/photos /data/photos/sorted

set -euo pipefail

LANGGRAPH_PORT="${LANGGRAPH_PORT:-8000}"
BASE_URL="http://127.0.0.1:${LANGGRAPH_PORT}"

SOURCE_DIR="${1:-/data/photos}"
TARGET_DIR="${2:-${SOURCE_DIR}/sorted}"

# 等待 LangGraph Server 就绪
for i in $(seq 1 15); do
    if curl -sf "${BASE_URL}/info" >/dev/null 2>&1; then
        break
    fi
    if [[ $i -eq 15 ]]; then
        echo '{"error":"LangGraph server not available"}' >&2
        exit 1
    fi
    sleep 2
done

TASK_ID="task-$(openssl rand -hex 6)"

# 创建线程
THREAD_RESP="$(curl -sf -X POST "${BASE_URL}/threads" \
    -H "Content-Type: application/json" \
    -d '{}')"
THREAD_ID="$(echo "$THREAD_RESP" | python3 -c \
    'import sys,json; d=json.load(sys.stdin); print(d.get("thread_id", d.get("id","")))')"

if [[ -z "$THREAD_ID" ]]; then
    echo "{\"error\":\"failed to create thread\",\"response\":${THREAD_RESP}}" >&2
    exit 1
fi

# 构建照片分拣工作流初始状态
INITIAL_STATE=$(cat <<JSON
{
  "source_dir": "${SOURCE_DIR}",
  "target_dir": "${TARGET_DIR}",
  "photos": [],
  "results": [],
  "duplicates": [],
  "similars": [],
  "report_path": null,
  "errors": []
}
JSON
)

RUN_PAYLOAD=$(python3 -c "
import json, sys
state = json.loads(sys.stdin.read())
print(json.dumps({'graph_id': 'photo_sorter', 'input': state}))
" <<< "$INITIAL_STATE")

# 启动工作流 run（异步）
RUN_RESP=""
RUN_ERROR=""
for RUN_KEY in assistant_id graph_id; do
    if RUN_RESP="$(curl -sf -X POST "${BASE_URL}/threads/${THREAD_ID}/runs" \
        -H "Content-Type: application/json" \
        -d "$RUN_PAYLOAD" 2>&1)"; then
        RUN_ERROR=""
        break
    fi
    RUN_ERROR="$RUN_RESP"
    RUN_RESP=""
done

if [[ -z "$RUN_RESP" ]]; then
    echo "{\"error\":\"failed to start run: ${RUN_ERROR}\"}" >&2
    exit 1
fi

RUN_ID="$(echo "$RUN_RESP" | python3 -c \
    'import sys,json; d=json.load(sys.stdin); print(d.get("run_id", d.get("id","")))')"

python3 -c "
import json
print(json.dumps({
    'task_id':   '${TASK_ID}',
    'thread_id': '${THREAD_ID}',
    'run_id':    '${RUN_ID}',
    'workflow':  'photo_sorter',
    'status':    'started',
    'source_dir':'${SOURCE_DIR}',
    'target_dir':'${TARGET_DIR}',
    'message':   '照片分拣工作流已启动，可通过 LangGraph Studio 查看进度',
    'studio_url': 'https://smith.langchain.com/studio/?baseUrl=http://127.0.0.1:${LANGGRAPH_PORT}'
}, ensure_ascii=False))
"
