INIT_MODE=auto

PROVIDER_NAME=kimi
PROVIDER_BASE_URL=https://api.kimi.com/coding/v1
PROVIDER_API_TYPE=anthropic-messages
MODEL_ID=kimi-for-coding
MODEL_NAME=Kimi Code
PRIMARY_MODEL=kimi/kimi-for-coding

KIMI_API_KEY=sk-kimi-xx
API_KEY=sk-kimi-xx

OPENCLAW_GATEWAY_PORT=18789
LANGGRAPH_PORT=8000
OPENCODE_PORT=4096

OPENCODE_ZEN_API_KEY=sk-xx
OPENCODE_PRIMARY_MODEL=kimi-for-coding/k2p5
OPENCODE_SKIP_PERMISSIONS=true
LANGGRAPH_PERSISTENCE=true

OPENAI_API_KEY=sk-kimi-xx
OPENAI_BASE_URL=https://api.kimi.com/coding/v1

CODE_DIR=./data/code

# 飞书消息渠道
FEISHU_APP_ID=xx
FEISHU_APP_SECRET=zz

# Human-in-the-Loop 通知 Webhook（可选，但强烈建议配置）
# 在飞书群机器人设置中获取 Webhook URL，用于 LangGraph 工作流中断时通知用户
FEISHU_NOTIFY_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/32f68557-d972-49fa-830d-zz

# 飞书自定义机器人签名密钥（可选，建议开启以提高安全性）
# 在飞书群机器人"安全设置"中开启"签名校验"后，复制此处的密钥
# 如果不配置，Webhook 调用将不携带签名，仅在飞书未开启签名校验时可用
FEISHU_NOTIFY_SECRET=ss
