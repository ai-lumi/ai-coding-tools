# ========================================
# 多 Agent 工具链 - 环境变量配置
# ========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# 启动模式:
#   interactive - 首次启动进入中文交互向导（需 attach 到容器终端）
#   auto        - 自动读取下方 LLM 配置完成初始化（推荐）
#   skip        - 跳过初始化向导
#   reset       - 清除初始化标记并重新进入交互向导
INIT_MODE=auto

# ========================================
# LLM 提供商配置（自动初始化必填）
# ========================================
# Provider 名称（自定义时请使用英文小写标识）
# 推荐：deepseek（新用户有免费额度，OpenAI 兼容）
# 可选内置 provider（Kimi 等有内置路由，无需额外配置）：
#   opencode      - OpenClaw 内置 OpenCode Zen 路由（忽略 PROVIDER_BASE_URL）
#   kimi          - Kimi Code（需 KIMI_API_KEY）
#   deepseek      - DeepSeek
#   openai        - OpenAI
#   anthropic     - Anthropic Claude
#
# 注意：内置 opencode provider 有硬编码路由，会忽略 PROVIDER_BASE_URL。
#       如需通过 api.opencode.ai 直连 OpenCode Zen，请用自定义名称如 opencode-zen：
#         PROVIDER_NAME=opencode-zen
#         PROVIDER_BASE_URL=https://api.opencode.ai/v1
#         PRIMARY_MODEL=opencode-zen/deepseek-v4-flash
#       同时显式设 OPENCODE_PRIMARY_MODEL=opencode/deepseek-v4-flash（供 OpenCode 自身使用）
PROVIDER_NAME=deepseek

# API Base URL（OpenAI 兼容接口）
# OpenAI:    https://api.openai.com/v1
# Moonshot:  https://api.moonshot.cn/v1
# DeepSeek:  https://api.deepseek.com/v1
# Kimi Code: https://api.kimi.com/coding/
# 自定义:    https://api.example.com/v1
# 注意：内置 provider (kimi 等) 有内置路由，此字段可留空
PROVIDER_BASE_URL=https://api.deepseek.com/v1

# API 类型
# DeepSeek/Moonshot 通用聊天接口使用 openai-completions
PROVIDER_API_TYPE=openai-completions

# 模型 ID
# DeepSeek V4 Flash: deepseek-v4-flash（速度快、成本低）
# DeepSeek V4 Pro:   deepseek-v4-pro
# Kimi for Coding:   kimi-for-coding
# OpenCode Zen:      gpt-5.1-codex / gpt-5.2 / claude-sonnet-4-5
MODEL_ID=deepseek-v4-flash

# 模型显示名称
MODEL_NAME=DeepSeek V4 Flash

# PRIMARY_MODEL 格式：provider/model-id
# 示例：
#   deepseek/deepseek-v4-flash
#   opencode/gpt-5.1-codex
#   kimi/kimi-for-coding
PRIMARY_MODEL=deepseek/deepseek-v4-flash

# DeepSeek API Key（新用户有免费额度）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Kimi Code API Key（api.kimi.com/coding，anthropic-messages 协议）
KIMI_API_KEY=your-kimi-api-key-here

# OpenCode Zen API Key（OpenCode 官方免费/付费模型网关）
# 获取：https://opencode.ai/auth
# 支持的模型：opencode/gpt-5.1-codex, opencode/claude-sonnet-4-5 等
OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key-here

# 通用 LLM API Key（自动初始化时优先级：OPENCODE_ZEN_API_KEY > KIMI_API_KEY > DEEPSEEK_API_KEY）
# 注意：此值用作主提供商（PROVIDER_NAME）的 apiKey。
# 如果配置了 FALLBACK_PROVIDER_NAME，请设置 FALLBACK_API_KEY 或对应的 ${PROVIDER^^}_API_KEY。
API_KEY=${OPENCODE_ZEN_API_KEY:-${KIMI_API_KEY:-${DEEPSEEK_API_KEY}}}

# ========================================
# Fallback 提供商配置（可选，主模型额度耗尽自动切换）
# ========================================
# 设置 FALLBACK_PROVIDER_NAME 后，OpenClaw 会在主模型认证/额度失败时自动切到 fallback 模型。
# 支持的 provider 名称：opencode, kimi, deepseek, openai, anthropic 等
# 内置 provider (opencode, kimi) 会自动推断 baseUrl 和 apiType，其他需手动指定。
#
# 示例：主用 OpenCode Zen，备用 Kimi Code
# FALLBACK_PROVIDER_NAME=kimi
# FALLBACK_BASE_URL=https://api.kimi.com/coding/v1
# FALLBACK_API_TYPE=anthropic-messages
# FALLBACK_MODEL_ID=kimi-for-coding
# FALLBACK_MODEL_NAME=Kimi Code
# FALLBACK_MODEL=kimi/kimi-for-coding
# FALLBACK_API_KEY=${KIMI_API_KEY}
#
# 如果不设置 FALLBACK_API_KEY，会从 KIMI_API_KEY / DEEPSEEK_API_KEY 等专用变量自动读取。
# 例如 FALLBACK_PROVIDER_NAME=kimi 时自动使用 KIMI_API_KEY。
FALLBACK_PROVIDER_NAME=
FALLBACK_BASE_URL=
FALLBACK_API_TYPE=
FALLBACK_MODEL_ID=
FALLBACK_MODEL_NAME=
FALLBACK_MODEL=
FALLBACK_API_KEY=

# ========================================
# 模型层级与额度耗尽切换（LangGraph 工作流用）
# ========================================
# 设置 FALLBACK_PROVIDER_NAME 后，init-wizard 会自动将主模型和 fallback 模型追加到此列表。
# 也可以手动指定更复杂的模型层级：
# MODEL_TIERS=opencode/gpt-5.1-codex,kimi-for-coding/k2p5,opencode/claude-sonnet-4-5
# MODEL_TIER_NAMES=OpenCode Zen免费,Kimi Code付费,OpenCode Claude付费
#
# 模型状态文件（持久化失败记录和人类选择）
# MODEL_STATE_FILE=/data/langgraph/model_state.json

# ========================================
# 角色模型配置（可选）
# ========================================
# 每个角色可单独指定模型，留空则全部使用 PRIMARY_MODEL
# 示例：让架构师用更强的模型，文档工程师用轻量模型
# ROLE_ARCHITECT_MODEL=kimi/kimi-for-coding
# ROLE_TECHNICAL_WRITER_MODEL=kimi/kimi-for-coding

# ========================================
# 可选工作流节点开关
# ========================================
# ENABLE_SECURITY_REVIEW=true
# ENABLE_API_REVIEW=true

# ========================================
# 卷映射配置
# ========================================
# 数据卷根路径（默认 ./data，即 docker/data/；NAS 改为绝对路径如 /share/Container/ai-workspace/data）
DATA_DIR=./data

# ========================================
# OpenClaw Gateway 配置
# ========================================
# Gateway 端口
OPENCLAW_GATEWAY_PORT=18789

# Gateway 认证 Token（留空则自动生成 32 位 hex）
OPENCLAW_GATEWAY_TOKEN=

# ========================================
# LangGraph Server 配置
# ========================================
LANGGRAPH_PORT=8000
# 端口绑定地址（默认仅本地；NAS 改为空以允许外部访问）
LANGGRAPH_BIND=127.0.0.1
# 是否启用 SQLite checkpoint 持久化（建议 true）
LANGGRAPH_PERSISTENCE=true
# checkpoint 文件路径（容器内路径）
LANGGRAPH_CHECKPOINT_PATH=/data/langgraph/checkpoints.sqlite

# ========================================
# OpenCode HTTP Server 配置
# ========================================
# opencode serve 监听端口（默认 4096）
OPENCODE_PORT=4096
# HTTP Basic Auth 密码（留空则无需鉴权；内网容器间通信可留空）
OPENCODE_SERVER_PASSWORD=
# 自动化场景建议开启，避免写文件时阻塞等待确认
OPENCODE_SKIP_PERMISSIONS=true

# OpenCode 模型（可独立于 OpenClaw 设置）
# 格式：provider_id/model_id
#   opencode/gpt-5.1-codex       → OpenCode Zen
#   kimi-for-coding/k2p5         → Kimi Code
#   deepseek/deepseek-v4-flash   → DeepSeek（OpenAI 兼容）
# 留空则 init-wizard 根据 PROVIDER_NAME 自动映射
OPENCODE_PRIMARY_MODEL=

# OpenCode 内置 provider 可识别的 API Key 环境变量：
#   opencode  provider → OPENCODE_ZEN_API_KEY
#   kimi-for-coding    → KIMI_API_KEY
#   openai provider    → OPENAI_API_KEY
#   anthropic provider → ANTHROPIC_API_KEY

# ========================================
# 其他 API Keys（如需要）
# ========================================
# OpenCode 在 OpenAI 兼容模式下会读取这两个变量
OPENAI_API_KEY=${API_KEY}
OPENAI_BASE_URL=${PROVIDER_BASE_URL}
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=${API_KEY}

# ========================================
# 消息渠道（可选）
# ========================================
# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# Human-in-the-Loop 通知 Webhook（强烈建议配置）
# 说明：LangGraph 工作流在需求评审、架构评审、代码评审等阶段
# 需要人工介入时，会通过此 Webhook 发送通知到飞书群。
# 获取方式：在飞书群聊中添加"自定义机器人"，复制 Webhook 地址。
# 如果没有配置，审批通知不会发送到飞书，需要手动检查工作流状态。
FEISHU_NOTIFY_WEBHOOK=

# 飞书自定义机器人签名密钥（可选，强烈建议开启）
# 说明：在飞书群机器人"安全设置"中开启"签名校验"后，复制此处的密钥。
# 配置后，LangGraph 发送通知时会自动计算签名（HmacSHA256 + Base64），
# 防止 Webhook 地址泄露后被恶意调用。如果飞书端开启了签名校验但此处未配置，
# 通知将发送失败并返回 "sign match fail" 错误。
FEISHU_NOTIFY_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
# Human-in-the-Loop 通知 chat_id（可选）
TELEGRAM_CHAT_ID=

# ========================================
# 业务数据目录（不指定则默认 ${DATA_DIR}/photos 等）
# ========================================
# PHOTOS_DIR=/volume1/photos
# CODE_DIR=/volume1/code
# KNOWLEDGE_DIR=/volume1/knowledge
